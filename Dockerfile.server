FROM node:24-bookworm-slim

WORKDIR /app/apps/web

COPY apps/web/package*.json ./
RUN npm ci

COPY apps/web ./
RUN npm run build

WORKDIR /app/apps/server

COPY apps/server/package*.json ./
RUN npm ci

COPY apps/server ./

ENV PORT=3009
ENV DATA_DIR=/app/data
ENV WEB_ROOT=/app/apps/web/dist

EXPOSE 3009

CMD ["npm", "start"]
