PORT=3009
DATA_DIR=/app/data

# Required for deployed admin upload protection.
ADMIN_PASSWORD=change-this-admin-password

# Absolute origin embedded in public QR codes.
PUBLIC_BASE_URL=https://modelbase.parametricstandards.com

# Required for server/worker API communication.
# This IS the internal worker secret (Phase 1 "WORKER_SECRET"): worker job
# polling/completion routes authenticate with `Authorization: Bearer <token>`,
# never with browser sessions. Keep it out of logs.
WORKER_API_TOKEN=change-this-worker-token

# =====================================================================
# Professional accounts (Phase 1) — feature-flagged, default OFF.
# When AUTH_ENABLED is false (the default), the legacy ADMIN_PASSWORD Basic-auth
# admin flow and all existing SQLite model flows are unchanged. Set to true only
# after PostgreSQL + real OAuth credentials below are configured. See
# docs/accounts-phase1.md for the full enablement runbook.
# =====================================================================
AUTH_ENABLED=false

# Canonical public origin of the app, used to build OAuth redirect URIs and
# session cookies. Falls back to PUBLIC_BASE_URL, then http://localhost:3009.
APP_BASE_URL=https://modelbase.parametricstandards.com

# PostgreSQL (auth/account layer only in Phase 1: users, auth_identities,
# sessions, organizations, organization_memberships, audit_events). Never expose
# the database publicly; the server reaches it over the Docker network.
DATABASE_URL=postgres://modelbase:change-this-db-password@postgres:5432/modelbase
POSTGRES_DB=modelbase
POSTGRES_USER=modelbase
POSTGRES_PASSWORD=change-this-db-password

# Opaque session cookie. SESSION_SECRET signs the short-lived OAuth transaction
# cookie (state/nonce/PKCE) — generate a long random value and keep it secret.
SESSION_COOKIE_NAME=modelbase_session
SESSION_SECRET=change-this-session-secret
# Optional: session lifetime in days (default 30) and cookie hardening.
SESSION_TTL_DAYS=30
SESSION_COOKIE_SAMESITE=lax
# SESSION_COOKIE_SECURE defaults to true when NODE_ENV=production.

# Google OIDC (https://console.cloud.google.com/apis/credentials).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft OIDC (https://entra.microsoft.com → App registrations).
# Tenant "common" allows both personal and work/school Microsoft accounts.
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT=common

# Worker settings.
SERVER_URL=http://server:3009
POLL_INTERVAL_SECONDS=15
WORKER_MAX_CONCURRENT_JOBS=3
WORKER_OUTPUT_DIR=/app/worker-output
KEEP_WORKER_OUTPUT=true

# Maximum source upload file size (500 MB).
MAX_UPLOAD_BYTES=524288000

# Maximum size of a single uploaded chunk (50 MB).
MAX_UPLOAD_CHUNK_BYTES=52428800

# Maximum converted display.glb accepted during the worker/server handoff (250 MB).
MAX_MODEL_ARTIFACT_BYTES=262144000

# occt-js | xcaf-baseline
# occt-js uses the existing JavaScript occt-import-js converter.
# xcaf-baseline uses native OpenCascade/XCAF metadata only; material rules,
# name guesses, raw STEP styled-item colours, layer-colour assignment, and
# default sRGB-to-linear conversion are disabled.
CONVERTER_BACKEND=occt-js
CONVERTER_CLI=/app/apps/converter/src/cli.js
XCAF_CONVERTER_BIN=/app/bin/xcaf-step-to-glb
# xcaf-baseline | step-presentation
# step-presentation keeps XCAF hierarchy/transforms/direct colours and maps
# STEP STYLED_ITEM presentation colours to matching exported topology.
XCAF_COLOUR_MODE=xcaf-baseline
# fast | balanced | high | detailed
CONVERTER_QUALITY=high

# off | fallback | override
# fallback keeps reliable STEP colours and only uses rules for uncoloured meshes.
# override forces matching rules when STEP colours are inconsistent.
MATERIAL_RULES_MODE=fallback
MATERIAL_RULES_PATH=/app/config/material-rules.json

# disabled | meshopt
# disabled does not apply post-process compression or quantization (raw passthrough).
# meshopt applies direct glTF-Transform quantization and EXT_meshopt_compression.
GLB_OPTIMIZATION_MODE=disabled

# Large STEP Chunking Mode (disabled | auto | direct-filter)
# disabled: process the STEP file normally as a single unit.
# auto: adaptive chunking using file size, lightweight pre-scan, and dynamic resource checks.
# direct-filter: run xcaf-step-planner directly to partition model structure and merge.
LARGE_STEP_CHUNKING_MODE=disabled

# Chunk concurrency mode (fixed | adaptive)
LARGE_STEP_CHUNK_CONCURRENCY_MODE=adaptive

# Auto decision thresholds
LARGE_STEP_AUTO_MIN_FILE_SIZE_MB=25
LARGE_STEP_AUTO_PLANNER_FILE_SIZE_MB=80
LARGE_STEP_AUTO_PRESCAN_ENABLED=true
LARGE_STEP_FORCE_PLANNER=false

# Planner complexity thresholds
LARGE_STEP_LEAF_COUNT_THRESHOLD=2000
LARGE_STEP_FACE_COUNT_THRESHOLD=50000
LARGE_STEP_WORK_SCORE_THRESHOLD=35000
LARGE_STEP_MIN_EXPECTED_SPEEDUP_FRACTION=0.15

# Chunk partition configuration
LARGE_STEP_TARGET_CHUNKS=3
LARGE_STEP_AUTO_MAX_TARGET_CHUNKS=6

# Concurrency & adaptive scheduler resource monitoring (used when LARGE_STEP_CHUNK_CONCURRENCY_MODE=adaptive)
LARGE_STEP_MIN_CONCURRENT_CHUNKS=1
LARGE_STEP_INITIAL_CONCURRENT_CHUNKS=2
LARGE_STEP_MAX_CONCURRENT_CHUNKS=3
LARGE_STEP_RESOURCE_POLL_SECONDS=10
LARGE_STEP_MAX_WORKER_MEMORY_FRACTION=0.75
LARGE_STEP_MIN_FREE_MEMORY_MB=900
LARGE_STEP_MAX_SWAP_GROWTH_MB=512
LARGE_STEP_EMERGENCY_MEMORY_FRACTION=0.92

# Adaptive scale-up safeguards and headroom checks
LARGE_STEP_SCALE_UP_WARMUP_SECONDS=300
LARGE_STEP_SCALE_UP_COOLDOWN_SECONDS=120
LARGE_STEP_ESTIMATED_CHUNK_MEMORY_MB=2600
LARGE_STEP_SCALE_UP_MIN_FREE_AFTER_RESERVE_MB=900
LARGE_STEP_MEMORY_BASED_MAX_CAP_ENABLED=true

# fail | full-conversion
# fail: if planner or chunk conversion fails, fail the job.
# full-conversion: if chunking fails, clean up chunk files/directories and run a normal full baseline conversion.
LARGE_STEP_CHUNK_FALLBACK_MODE=fail
