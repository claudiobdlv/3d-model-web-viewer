PORT=3009
DATA_DIR=/app/data

# Required for deployed admin upload protection.
ADMIN_PASSWORD=change-this-admin-password

# Absolute origin embedded in public QR codes.
PUBLIC_BASE_URL=https://modelbase.parametricstandards.com

# Required for server/worker API communication.
WORKER_API_TOKEN=change-this-worker-token

# Worker settings.
SERVER_URL=http://server:3009
POLL_INTERVAL_SECONDS=15
WORKER_MAX_CONCURRENT_JOBS=3
WORKER_OUTPUT_DIR=/app/worker-output
KEEP_WORKER_OUTPUT=true

# Maximum source upload file size (500 MB).
MAX_UPLOAD_BYTES=524288000

# Maximum size of a single uploaded chunk (50 MB).
MAX_UPLOAD_CHUNK_BYTES=52428800

# Maximum converted display.glb accepted during the worker/server handoff (250 MB).
MAX_MODEL_ARTIFACT_BYTES=262144000

# occt-js | xcaf-baseline
# occt-js uses the existing JavaScript occt-import-js converter.
# xcaf-baseline uses native OpenCascade/XCAF metadata only; material rules,
# name guesses, raw STEP styled-item colours, layer-colour assignment, and
# default sRGB-to-linear conversion are disabled.
CONVERTER_BACKEND=occt-js
CONVERTER_CLI=/app/apps/converter/src/cli.js
XCAF_CONVERTER_BIN=/app/bin/xcaf-step-to-glb
# xcaf-baseline | step-presentation
# step-presentation keeps XCAF hierarchy/transforms/direct colours and maps
# STEP STYLED_ITEM presentation colours to matching exported topology.
XCAF_COLOUR_MODE=xcaf-baseline
# fast | balanced | high | detailed
CONVERTER_QUALITY=high

# off | fallback | override
# fallback keeps reliable STEP colours and only uses rules for uncoloured meshes.
# override forces matching rules when STEP colours are inconsistent.
MATERIAL_RULES_MODE=fallback
MATERIAL_RULES_PATH=/app/config/material-rules.json

# disabled | meshopt
# disabled does not apply post-process compression or quantization (raw passthrough).
# meshopt applies direct glTF-Transform quantization and EXT_meshopt_compression.
GLB_OPTIMIZATION_MODE=disabled

# Large STEP Chunking Mode (disabled | direct-filter)
# disabled: process the STEP file normally as a single unit.
# direct-filter: run xcaf-step-planner, partition model structure into parallel chunks, convert chunks via xcaf-step-to-glb, and merge.
LARGE_STEP_CHUNKING_MODE=disabled

# fail | full-conversion
# fail: if planner or chunk conversion fails, fail the job.
# full-conversion: if chunking fails, clean up chunk files/directories and run a normal full baseline conversion.
LARGE_STEP_CHUNK_FALLBACK_MODE=fail

# Thresholds for triggering large STEP chunking.
LARGE_STEP_FILE_SIZE_THRESHOLD_MB=80
LARGE_STEP_LEAF_COUNT_THRESHOLD=2000
LARGE_STEP_FACE_COUNT_THRESHOLD=50000

# Number of chunk partitions to generate, and limit of concurrent chunk converter tasks.
LARGE_STEP_TARGET_CHUNKS=3
LARGE_STEP_MAX_CONCURRENT_CHUNKS=3
